          checklistItems.forEach((item, index) => {
              const itemDiv = document.createElement('div');
              itemDiv.style.cssText = 'display: flex; align-items: center; gap: 10px; padding: 8px 12px; background: rgba(255,255,255,0.03); border-radius: 6px; margin-bottom: 6px; transition: background 0.2s;';
