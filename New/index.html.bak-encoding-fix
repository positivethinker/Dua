              return;
          }

          currentState.isAllMode = false; currentState.sectionIndex = sIdx;
          let validIdx = vIdx;
          while(validIdx < videoSections[sIdx].videos.length && videoSections[sIdx].videos[validIdx].isSubcategory) validIdx++;
