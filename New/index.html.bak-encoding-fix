      let videoSections;

      async function initializeData() {
          // 1. Try Supabase
          if (_supabase && SUPABASE_URL !== 'YOUR_SUPABASE_URL') {
              try {
                  const { data: sections, error: sError } = await _supabase
                      .from('sections')
                      .select('*')
                      .order('order_index');
                  
                  if (!sError && sections && sections.length > 0) {
                      const { data: videos, error: vError } = await _supabase
                          .from('videos')
                          .select('*')
                          .order('order_index');
                      
                      if (!vError && videos) {
                          videoSections = sections.map(s => ({
                              name: s.name,
                              videos: videos
                                  .filter(v => v.section_id === s.id)
                                  .map(v => ({
                                      id: v.youtube_id,
                                      start: v.start_time,
                                      end: v.end_time,
                                      label: v.label,
                                      tooltip: v.tooltip,
                                      loop: v.loop_count,
                                      isSubcategory: v.is_subcategory
                                  }))
                          }));
                      }
                  }
              } catch (e) { console.error("Supabase load failed", e); }
          }

          // 2. Try LocalStorage if Supabase failed or not configured
          if (!videoSections) {
              try {
                  const stored = localStorage.getItem("duaDarudVideoSections");
                  if (stored) {
                      const parsed = JSON.parse(stored);
                      if (Array.isArray(parsed) && parsed.length > 0) videoSections = parsed;
