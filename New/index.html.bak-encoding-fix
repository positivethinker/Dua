          document.querySelectorAll(".video-list").forEach(el => el.classList.remove("open"));
          document.querySelectorAll(".section-header").forEach(el => el.classList.remove("active"));
          if (forceOpen || !wasOpen) { 
              list.classList.add("open"); 
              list.previousElementSibling.classList.add("active"); 
              // Auto scroll section into view
              if (!wasOpen || forceOpen) {
                  list.parentElement.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
              }
          }
      }

