              div.className = 'video-item';
              div.style.display = 'flex';
              div.onclick = () => { playFromHistory(item.id); };
              div.innerHTML = `<span>ðŸ•’ ${item.label}</span>`;
              container.appendChild(div);
          });
          playlist.appendChild(container);
      }
      
      function playFromHistory(vidId) {
          // We need to find the section indices to start properly
          for(let s=0; s<videoSections.length; s++) {
              for(let v=0; v<videoSections[s].videos.length; v++) {
                  if(videoSections[s].videos[v].id === vidId) {
                      startVideo(s, v);
                      return;
                  }
              }
          }
      }



