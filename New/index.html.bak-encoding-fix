      function setSpeed(rate) {
          if (player && player.setPlaybackRate) {
              player.setPlaybackRate(rate);
          }
          document.querySelectorAll('.speed-btn').forEach(b => b.classList.remove('active'));
          // Find button with matching onclick
          // Simpler: just loop and check text or ID if assigned.
          // Let's just highlight based on value if we assign IDs, or just find by text
          Array.from(document.querySelectorAll('.speed-btn')).forEach(b => {
             if(b.textContent.includes(rate + 'x') || (rate===1 && b.textContent === '1x')) b.classList.add('active');
