              isFavFilterActive = false; document.getElementById('favFilterBtn').classList.remove('active');
              renderHistory();
          } else {
              btn.classList.remove('active');
              location.reload(); // Simplest way to restore full playlist view correctly without complex DOM restoration logic for now
