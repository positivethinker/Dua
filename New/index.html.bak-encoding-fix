          createProgressSegments(currentState.maxLoops);

          if(player && player.loadVideoById) { player.loadVideoById({ videoId: video.id, startSeconds: video.start }); }
      }
      
      function createProgressSegments(loopCount) {
          const container = document.getElementById('progressContainer');
          if (!container) return;

          const loops = Math.max(1, parseInt(loopCount, 10) || 1);
          container.innerHTML = '';

          const size = 320;
          const center = size / 2;
          const outerRadius = 128;
          const minInnerRadius = 44;
          const radiusStep = loops === 1 ? 0 : (outerRadius - minInnerRadius) / (loops - 1);
          const strokeWidth = loops === 1 ? 12 : Math.max(3, Math.min(10, radiusStep - 2));
          const palette = ['#34d399', '#60a5fa', '#f59e0b', '#22d3ee', '#f472b6', '#a78bfa'];
          const svgNs = 'http://www.w3.org/2000/svg';

          const svg = document.createElementNS(svgNs, 'svg');
          svg.setAttribute('class', 'radial-progress-svg');
          svg.setAttribute('viewBox', `0 0 ${size} ${size}`);

          for (let i = 0; i < loops; i++) {
              const radius = outerRadius - (i * radiusStep);
              const circumference = 2 * Math.PI * radius;
              const color = palette[i % palette.length];

              const track = document.createElementNS(svgNs, 'circle');
              track.setAttribute('class', 'loop-ring-track');
              track.setAttribute('cx', center);
              track.setAttribute('cy', center);
              track.setAttribute('r', radius);
              track.setAttribute('stroke-width', strokeWidth);
              svg.appendChild(track);

              const fill = document.createElementNS(svgNs, 'circle');
              fill.setAttribute('class', 'loop-ring-fill');
              fill.setAttribute('cx', center);
              fill.setAttribute('cy', center);
              fill.setAttribute('r', radius);
              fill.setAttribute('stroke-width', strokeWidth);
              fill.setAttribute('stroke', color);
              fill.setAttribute('stroke-dasharray', circumference.toString());
              fill.setAttribute('stroke-dashoffset', circumference.toString());
              fill.dataset.loopIndex = i.toString();
              fill.dataset.circumference = circumference.toString();
              svg.appendChild(fill);
          }

          const centerInfo = document.createElement('div');
          centerInfo.className = 'radial-progress-center';
          centerInfo.innerHTML = `
              <div class="radial-progress-label">Loop</div>
              <div class="radial-progress-value" id="radialLoopValue">1/${loops}</div>
              <div class="radial-progress-percent" id="radialLoopPercent">--:--</div>
          `;

          container.appendChild(svg);
          container.appendChild(centerInfo);
          updateRadialProgress(0);
      }

      function updateRadialProgress(currentPct, remainingSeconds = null) {
          const rings = document.querySelectorAll('.loop-ring-fill');
          rings.forEach((ring, idx) => {
              const circumference = parseFloat(ring.dataset.circumference || '0');
              let fillPct = 0;

              if (idx < currentState.loopCount) fillPct = 100;
              else if (idx === currentState.loopCount) fillPct = Math.max(0, Math.min(100, currentPct));

              ring.style.strokeDashoffset = (circumference * (1 - (fillPct / 100))).toString();
          });

          const valueEl = document.getElementById('radialLoopValue');
          const pctEl = document.getElementById('radialLoopPercent');
          if (valueEl) {
              const currentLoop = Math.min(currentState.loopCount + 1, Math.max(1, currentState.maxLoops));
              valueEl.textContent = `${currentLoop}/${Math.max(1, currentState.maxLoops)}`;
          }
          if (pctEl) {
              pctEl.textContent = remainingSeconds === null ? '--:--' : formatTime(Math.max(0, remainingSeconds));
          }
      }
      
      function onPlayerStateChange(event) {
          if (event.data === YT.PlayerState.PLAYING || event.data === YT.PlayerState.BUFFERING) {
              startLoopCheck();
              setRemainingBadgeVisible(false);
          } else {
              clearInterval(timers.loopCheck);
              if (event.data !== YT.PlayerState.ENDED) setRemainingBadgeVisible(true);
          }
          if (event.data === YT.PlayerState.ENDED) handleVideoEnd();
      }

      function startLoopCheck() {
          clearInterval(timers.loopCheck);
          timers.loopCheck = setInterval(() => {
              if(!player || !player.getCurrentTime) return;
              const cur = player.getCurrentTime();
              const v = videoSections[currentState.sectionIndex].videos[currentState.videoIndex];
              const guardedEnd = Math.max(v.start, v.end - PRE_END_GUARD_SECONDS);
              if (cur >= guardedEnd) { handleVideoEnd(); return; }
              const remaining = Math.max(0, v.end - cur);
              document.getElementById("remainingTime").textContent = formatTime(remaining);
              
              // Update radial loop progress
              const duration = v.end - v.start;
              const elapsed = cur - v.start;
              const pct = Math.min(100, Math.max(0, (elapsed / duration) * 100));
              updateRadialProgress(pct, remaining);

              updateTotalTimer();
          }, 500);
      }

      function updateTotalTimer() {
          // If the badge is hidden and we are not in 'All Mode', we might not need to update, 
          // but if the user manually showed it or we want to support it, we calculate.
          // Note: The badge is shown in playAllSections().
          
          let totalSeconds = 0;
          
          // 1. Remaining time in current video (current loop remainder + future loops)
          if (videoSections[currentState.sectionIndex]) {
             const currentVid = videoSections[currentState.sectionIndex].videos[currentState.videoIndex];
             if (currentVid && !currentVid.isSubcategory) {
                 const curTime = player.getCurrentTime ? player.getCurrentTime() : currentVid.start;
                 const segDuration = currentVid.end - currentVid.start;
                 
                 // Current loop remainder
                 let currentLoopRem = 0;
                 if (curTime < currentVid.end) {
                     currentLoopRem = currentVid.end - curTime;
                 }
                 
                 // Future loops
                 const loopsLeft = Math.max(0, currentState.maxLoops - currentState.loopCount - 1);
                 
                 totalSeconds += currentLoopRem + (loopsLeft * segDuration);
             }
          }

          // 2. Subsequent videos in current section
          const currentSection = videoSections[currentState.sectionIndex];
          if (currentSection) {
              for (let i = currentState.videoIndex + 1; i < currentSection.videos.length; i++) {
                  const vid = currentSection.videos[i];
                  if (vid.isSubcategory) continue;
                  const dur = vid.end - vid.start;
                  const loops = vid.loop || 1;
                  totalSeconds += (dur * loops);
              }
          }

          // 3. Subsequent sections (ONLY if in isAllMode)
          if (currentState.isAllMode) {
              for (let s = currentState.sectionIndex + 1; s < videoSections.length; s++) {
                  const sec = videoSections[s];
                  for (let v = 0; v < sec.videos.length; v++) {
                      const vid = sec.videos[v];
                      if (vid.isSubcategory) continue;
                      const dur = vid.end - vid.start;
                      const loops = vid.loop || 1;
                      totalSeconds += (dur * loops);
                  }
              }
          }

          document.getElementById("allTimer").textContent = formatTime(totalSeconds);
      }

      function handleVideoEnd() {
          if (isHandlingVideoEnd) return;
          isHandlingVideoEnd = true;

          currentState.loopCount++; updateStats();
          const v = videoSections[currentState.sectionIndex].videos[currentState.videoIndex];
          
          // Check Custom Loop
          let max = currentState.maxLoops;
          const custom = parseInt(document.getElementById('customLoopInput').value);
          if (custom && custom > 0) max = custom;

          if (currentState.loopCount < max) { player.seekTo(v.start, true); player.playVideo(); }
          else nextVideo();

          setTimeout(() => { isHandlingVideoEnd = false; }, 180);
      }


      // --- SECTION LOCK FEATURE ---
      function getSectionLocks() {
          try {
              return JSON.parse(localStorage.getItem('duaSectionLocks') || '{}');
          } catch (e) { return {}; }
      }

      function saveSectionLocks(locks) {
          localStorage.setItem('duaSectionLocks', JSON.stringify(locks));
      }

      function lockSection(sIdx) {
          const locks = getSectionLocks();
          const threeHours = 3 * 60 * 60 * 1000;
          locks[sIdx] = Date.now() + threeHours;
          saveSectionLocks(locks);
          renderPlaylist(); // Update UI
      }

      function isSectionLocked(sIdx) {
          const locks = getSectionLocks();
          if (!locks[sIdx]) return false;
          
          if (Date.now() > locks[sIdx]) {
              // Expired, remove it
              delete locks[sIdx];
              saveSectionLocks(locks);
              return false;
          }
          return true;
      }
      
      function getLockRemainingTime(sIdx) {
          const locks = getSectionLocks();
          if (!locks[sIdx]) return null;
          const remaining = locks[sIdx] - Date.now();
          if (remaining <= 0) return null;
          
          const h = Math.floor(remaining / (1000 * 60 * 60));
          const m = Math.floor((remaining % (1000 * 60 * 60)) / (1000 * 60));
          return `${h}h ${m}m`;
      }

      function showToast(message) {
          const container = document.getElementById('toastContainer');
          const toast = document.createElement('div');
          toast.className = 'toast';
          toast.innerHTML = `<span>âš ï¸</span> <span>${message}</span>`;
          container.appendChild(toast);
          
          // Trigger animation
          requestAnimationFrame(() => toast.classList.add('show'));
          
          // Remove after 3 seconds
          setTimeout(() => {
              toast.classList.remove('show');
              setTimeout(() => toast.remove(), 300);
          }, 3000);
      }
      
      // Update check for locks on load
      setInterval(() => {
          // periodically refresh to unlock expired sections
          const locks = getSectionLocks();
          let changed = false;
          Object.keys(locks).forEach(key => {
              if (Date.now() > locks[key]) {
                  delete locks[key];
                  changed = true;
              }
          });
          if (changed) {
              saveSectionLocks(locks);
              renderPlaylist();
          }
      }, 60000); // Check every minute

      // ---------------------------

      function nextVideo() {
          let sIdx = currentState.sectionIndex; let vIdx = currentState.videoIndex + 1;
          const section = videoSections[sIdx];
          
          // Find next valid video
          // Note: using while loop to check subcategories
          // We need to check if we are going out of bounds
          if (vIdx >= section.videos.length) {
              // End of section reached immediately
              finishSection(sIdx);
              return;
          }
          
          while(vIdx < section.videos.length && section.videos[vIdx].isSubcategory) vIdx++;
          
          if(vIdx < section.videos.length) {
              startVideo(sIdx, vIdx);
          } else {
              // End of section reached after skipping subcategories
              finishSection(sIdx);
          }
      }
      
      function finishSection(sIdx) {
          // Lock this section
          lockSection(sIdx);
          
          // Auto Play Logic: Move to next section
          if (currentState.isAllMode || isAutoPlayActive) {
              let nextSec = sIdx + 1;
              // Skip locked sections in auto-play
              while (nextSec < videoSections.length && isSectionLocked(nextSec)) {
                  nextSec++;
              }
              
              if (nextSec < videoSections.length) {
                  playSingleSection(nextSec, 0);
              } else {
                  stop();
              }
          } else {
              stop();
          }
      }

      function skipVideo() { nextVideo(); }
      function stop() { 
          if(player && player.stopVideo) player.stopVideo(); 
          document.getElementById("videoTitle").textContent = "Completed"; 
          setNowPlayingPanelTitle("Completed");
          const progressCaptionText = document.getElementById("progressCaptionText");
          if (progressCaptionText) progressCaptionText.textContent = "Playback completed";
          clearInterval(timers.loopCheck);
          setRemainingBadgeVisible(true);
      }
      function updateStats() {
          const displayLoop = Math.min(currentState.loopCount + 1, Math.max(1, currentState.maxLoops));
          document.getElementById("currentLoop").textContent = displayLoop;
          document.getElementById("maxLoop").textContent = currentState.maxLoops;
          const chip = document.getElementById("loopChip");
          if (chip) chip.textContent = `Loop ${displayLoop}/${Math.max(1, currentState.maxLoops)}`;
          updateRadialProgress(0);
      }
      function formatTime(s) { 
          const h = Math.floor(s / 3600);
          const m = Math.floor((s % 3600) / 60); 
          const sec = Math.floor(s % 60); 
          if(h > 0) return `${h}:${m < 10 ? '0'+m : m}:${sec < 10 ? '0'+sec : sec}`;
          return `${m}:${sec < 10 ? '0'+sec : sec}`; 
      }
      function copyDataForAdmin() { navigator.clipboard.writeText(JSON.stringify(videoSections, null, 2)); alert("Data copied!"); }
      
      // SEARCH, TASBIH, SPEED Logic
      function handleSearch(query) {
          const q = query.toLowerCase();
          document.querySelectorAll('.video-item').forEach(item => {
              const text = item.textContent.toLowerCase();
              if (text.includes(q)) {
                  item.style.display = 'flex';
                  // Open parent list if hidden
                  const list = item.parentElement;
                  if (!list.classList.contains('open') && q.length > 0) {
                      list.classList.add('open');
                      list.previousElementSibling.classList.add('active');
                  }
              } else {
                  item.style.display = 'none';
              }
          });
          
          // Hide empty sections
          document.querySelectorAll('.section-item').forEach(sec => {
              const visibleItems = sec.querySelectorAll('.video-item[style="display: flex;"]');
              const allItems = sec.querySelectorAll('.video-item');
              // If query is empty, show all
              if(q.length === 0) {
                  allItems.forEach(i => i.style.display = 'flex');
                  sec.style.display = 'block';
                  return;
              }
              // Check if any visible
              let hasVisible = false;
              allItems.forEach(i => { if(i.style.display !== 'none') hasVisible = true; });
              sec.style.display = hasVisible ? 'block' : 'none';
          });
      }



      // HISTORY
      let isHistoryActive = false;
      let playHistory = JSON.parse(localStorage.getItem('duaHistory') || '[]');

      function addToHistory(videoId, label) {
          // Remove if exists to push to top
          playHistory = playHistory.filter(h => h.id !== videoId);
          playHistory.unshift({ id: videoId, label: label, date: Date.now() });
          if(playHistory.length > 20) playHistory.pop(); // Keep last 20
          localStorage.setItem('duaHistory', JSON.stringify(playHistory));
          if(isHistoryActive) renderHistory();
      }

      function toggleHistoryView() {
          isHistoryActive = !isHistoryActive;
          const btn = document.getElementById('historyBtn');
          const playlist = document.getElementById('playlist');
          
          if (isHistoryActive) {
              btn.classList.add('active');
