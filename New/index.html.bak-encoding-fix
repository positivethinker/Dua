      function applyFavFilter() {
           const btn = document.getElementById('favFilterBtn');
           btn.textContent = isFavFilterActive ? "â¤ï¸ Show All" : "â¤ï¸ Show Favorites Only";
           
           document.querySelectorAll('.video-item').forEach(item => {
               // Subcategories should be hidden in fav mode unless they have visible children? 
               // For simplicity, hide subcategories in fav mode or keep them if we want structure.
               // Let's just filter selectable items.
               if (item.querySelector('.fav-btn')) {
                   const isFav = item.querySelector('.fav-btn').classList.contains('active');
                   if (isFavFilterActive && !isFav) {
                       item.style.display = 'none';
                   } else {
                       // Restore display if search is not active (we should combine logic really)
                       // Simple approach: remove style display none if it matches search
                       // But search also hides things. Ideally we re-run comprehensive filter.
                       // For now, let's just reset and let search handle it if search has input.
                       item.style.display = 'flex';
                   }
               }
           });
           
           // If we have a Search query, we should respect it too.
           const searchVal = document.querySelector('.search-input').value;
           if(searchVal) handleSearch(searchVal); // This re-applies search filter on top
           else {
               // Re-check section visibility
               document.querySelectorAll('.section-item').forEach(sec => {
                  if(isFavFilterActive) {
                      // Show section only if it has visible favorites
                      const visible = Array.from(sec.querySelectorAll('.video-item')).some(i => i.style.display !== 'none' && !i.style.fontWeight /* skip subheaders */);
                      sec.style.display = visible ? 'block' : 'none';
