      // SLEEP TIMER & SAVER
      let sleepTimer = null;
      let sleepMinutes = 0;
      
      function toggleSleepTimer() {
          const options = [0, 15, 30, 60];
          // Determine current step based on previous selection logic or just cycle
          // We can't rely on sleepMinutes if we decrement it. Check button text or keep 'selectedDuration' state?
          // Simpler: use a separate tracker for 'selectedSleepIndex'.
          
          if (typeof window.sleepIndex === 'undefined') window.sleepIndex = 0;
          window.sleepIndex = (window.sleepIndex + 1) % options.length;
          const mins = options[window.sleepIndex];
          
          if(sleepTimer) clearInterval(sleepTimer);
          
          const btn = document.getElementById('sleepBtn');
          
          if (mins > 0) {
              const endTime = Date.now() + (mins * 60 * 1000);
              btn.classList.add('active');
              
              // Update immediately
              updateSleepCountdown(endTime, btn);
              
              sleepTimer = setInterval(() => {
                  updateSleepCountdown(endTime, btn);
              }, 1000);
          } else {
              btn.textContent = `ðŸŒ™ Sleep`;
              btn.classList.remove('active');
          }
      }
      
      function updateSleepCountdown(endTime, btn) {
          const left = endTime - Date.now();
          if (left <= 0) {
              clearInterval(sleepTimer);
              btn.textContent = `ðŸŒ™ Sleep`;
              btn.classList.remove('active');
              window.sleepIndex = 0; // Reset cycle
              stop();
              // alert("Sleep Timer: Playback stopped."); // Removed alert to not block if user fell asleep
          } else {
              const m = Math.floor(left / 60000);
              const s = Math.floor((left % 60000) / 1000);
              btn.textContent = `ðŸŒ™ ${m}:${s < 10 ? '0'+s : s}`;
          }
      }

