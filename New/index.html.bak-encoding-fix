      function calculateSectionDuration(sectionIndex) {
          let totalSeconds = 0;
          const section = videoSections[sectionIndex];
          if (!section) return 0;
          
          section.videos.forEach(video => {
              if (video.isSubcategory) return; // Skip subcategories
              const duration = video.end - video.start;
              const loops = video.loop || 1;
              totalSeconds += duration * loops;
          });
          
          return totalSeconds;
      }

